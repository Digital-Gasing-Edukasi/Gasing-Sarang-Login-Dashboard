# ─────────────────────────────────────────────────────────────────────────────
# Gasing Circle — Environment Template
#
# Copy file ini jadi `.env`, lalu isi nilainya:
#   cp .env.example .env
#
# Catatan Vite:
#   - Hanya variabel berprefix `VITE_` yang diekspos ke kode frontend.
#   - Nilai di sini di-INLINE ke bundle JS saat build → siapa pun bisa baca.
#     Jangan pernah taruh secret/server key di variabel `VITE_`.
#   - Setelah mengubah .env, restart dev server (Ctrl+C lalu `npm run dev`).
# ─────────────────────────────────────────────────────────────────────────────

# Base URL backend NestJS. TANPA trailing slash, TANPA prefix /api.
# api.js menyambung langsung: `${VITE_API_URL}/auth/refresh`, `${VITE_API_URL}/regions`, dst.
VITE_API_URL=

# Nomor WhatsApp support, format internasional tanpa "+" dan tanpa spasi.
# Dipakai halaman Payment* dan TransferBankPage sebagai tombol bantuan.
# Fallback di kode: 628123456789
VITE_WA_NUMBER=

# ─── Midtrans ────────────────────────────────────────────────────────────────
# Client Key — aman di frontend. Disuntik ke index.html sebagai
# %VITE_MIDTRANS_CLIENT_KEY% pada <script src=".../snap.js">.
# Sandbox biasanya berawalan "SB-Mid-client-", production "Mid-client-".
VITE_MIDTRANS_CLIENT_KEY=

# Server Key — RAHASIA. Hanya untuk MidtransTestPage (dev lokal).
#
#   ⚠️  Karena berprefix VITE_, nilai ini IKUT TER-BUNDLE ke JS produksi
#       dan bisa dibaca siapa pun lewat DevTools. Server Key = akses penuh
#       ke akun Midtrans (refund, cek transaksi, charge).
#
# Biarkan KOSONG kecuali sedang memakai /?midtrans-test=true di localhost.
# WAJIB dikosongkan lagi sebelum `npm run build` untuk production.
VITE_MIDTRANS_SERVER_KEY=

# ─── Tidak dipakai kode (per 2026-07-10) ─────────────────────────────────────
# VITE_DISCOURSE_URL disebut di README.md & DEPLOYMENT_GUIDE.md, tapi tidak
# dibaca di mana pun dalam src/. Redirect Discourse datang dari `redirectUrl`
# milik response backend. Aktifkan hanya kalau nanti memang dipakai kode.
# VITE_DISCOURSE_URL=https://dev-komunitas.gasingacademy.org
